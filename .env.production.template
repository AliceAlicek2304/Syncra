# ==============================
# Syncra Production Environment
# ==============================
# Copy to .env and fill values.
# docker compose uses this file automatically.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# --- Postgres (managed / Supabase) ---
Postgres__Host=
Postgres__Port=5432
Postgres__Database=
Postgres__Username=
Postgres__Password=
Postgres__UseSsl=true

# --- Redis (Docker service) ---
Redis__Host=redis
Redis__Port=6379
Redis__Password=
Redis__Database=0

# --- JWT ---
Jwt__Secret=
Jwt__Issuer=Syncra
Jwt__Audience=Syncra
Jwt__ExpirationMinutes=1440
Jwt__RefreshTokenExpirationDays=7

# --- Wasabi S3 ---
Wasabi__AccessKey=
Wasabi__SecretKey=
Wasabi__ServiceUrl=https://s3.ap-southeast-1.wasabisys.com
Wasabi__BucketName=syncra-1

# --- Stripe ---
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=

# --- Zernio ---
Zernio__ApiKey=
Zernio__SecretKey=

# --- OAuth: Google ---
OAuth__Google__ClientId=
OAuth__Google__ClientSecret=
OAuth__Google__CallbackUrl=https://syncra.vn

# --- Gemini AI ---
Gemini__ApiKey=
Gemini__Model=gemini-2.5-flash
Gemini__Temperature=0.7
Gemini__MaxOutputTokens=8192

# --- Postmark (transactional email) ---
Postmark__ServerToken=
Postmark__FromEmail=
Postmark__FromName=Syncra

# --- Sentry ---
Sentry__Dsn=
Sentry__Environment=production
Sentry__TracesSampleRate=0.1
Sentry__EnableTracing=false

# --- Storage ---
Storage__BaseUrl=https://syncra.vn
Media__MaxFileSize=104857600
