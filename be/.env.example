# Copy this to .env and fill in the real values.
# Never commit the .env file.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Format: postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_URL=postgresql://postgres:<YOUR-PASSWORD>@db.qtzosjgnwpvmtnlcndkp.supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secure random string used to sign Flask sessions and JWT tokens.
JWT_SECRET=change-me-to-a-long-random-string
FLASK_SECRET_KEY=change-me-to-another-long-random-string

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth 2.0 client at https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173/api/auth/google/callback as an authorised redirect URI (dev).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── CORS / URLs ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (leave blank for localhost:5173 default).
# CORS_ORIGINS=https://your-domain.com

# URL the browser can reach the frontend at (used to build OAuth redirect URIs).
# FRONTEND_URL=http://localhost:5173

# Base path of the React app (matches vite.config.ts `base`).
# FRONTEND_BASE=/TechNest

# ── Flask ─────────────────────────────────────────────────────────────────────
# FLASK_DEBUG=false
# PORT=5000
